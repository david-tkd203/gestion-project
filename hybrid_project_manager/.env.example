# ─── Django ───
DJANGO_SECRET_KEY=generate-a-real-secret-key-with-openssl-rand-32
DJANGO_DEBUG=True

# ─── PostgreSQL ───
DB_PASSWORD=hybrid_pm_secret_2026

# ─── Celery ───
CELERY_CONCURRENCY=4

# ─── CORS (frontend URLs) ───
CORS_ORIGINS=http://localhost:3000,http://localhost

# ─── GitHub Integration ───
# Optional global fallback — per-project tokens are stored in DB (encrypted).
# Webhook secret: generate with `openssl rand -hex 32`
GITHUB_WEBHOOK_SECRET=

# ─── Email (Postfix local) ───
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=localhost
EMAIL_PORT=25
EMAIL_USE_TLS=False
EMAIL_USE_SSL=False
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=VINCULO <noreply@vinculosync.tech>
SERVER_EMAIL=noreply@vinculosync.tech

# ─── Site URL (for email links) ───
BASE_URL=http://localhost:3000

# ─── Hosts ───
ALLOWED_HOSTS=*,backend,localhost
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://localhost,http://backend:8000
